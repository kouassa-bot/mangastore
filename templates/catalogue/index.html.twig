<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Catalogue — MangaStore</title>
</head>
<body>
    <h1>Catalogue</h1>
    <a href="/">← Retour à l'accueil</a>

    <table border="1">
        <thead>
            <tr>
                <th>Titre</th>
                <th>Auteur</th>
                <th>Date de parution</th>
                <th>Genre</th>
                <th>Prix</th>
            </tr>
        </thead>
        <tbody>
            {% for manga in mangas %}
            <tr>
                <td>{{ manga.titre }}</td>
                <td>{{ manga.auteur }}</td>
                <td>{{ manga.date_parution }}</td>
                <td>{{ manga.genre }}</td>
                <td>{{ manga.prix }} €</td>
            </tr>
            {% else %}
            <tr>
                <td colspan="5">Aucun manga disponible.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</body>
</html>